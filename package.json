{
  "name": "@brenoxp/cc-statusline",
  "version": "1.0.7",
  "description": "Custom status line for Claude Code CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cc-statusline": "bin/cc-statusline"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brenoxp/claude-code-statusline"
  },
  "scripts": {
    "prepublishOnly": "bun run build",
    "build": "bun run build.ts",
    "test": "bash tests/run.sh",
    "format": "prettier --write \"src/**/*.{ts,svelte}\"",
    "lint": "biome check .",
    "lint:fix": "biome check --fix ."
  },
  "keywords": [
    "claude-code",
    "statusline",
    "cli",
    "terminal"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.0",
    "chalk": "^5.6.2",
    "cli-cursor": "^5.0.0",
    "esbuild": "^0.27.5",
    "nib-ink": "^0.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "string-width": "^8.2.0",
    "strip-ansi": "^7.2.0",
    "svelte": "^5.55.1",
    "yoga-layout": "^3.2.1"
  }
}
